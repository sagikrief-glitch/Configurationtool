// prisma/schema.prisma
// Switched from PostgreSQL to SQLite for zero-config local development
// SQLite does not support String[] arrays — tags stored as JSON string

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Configuration {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String?
  type        String    @default("json")
  market      String?
  provider    String?
  environment String?
  tags        String    @default("[]") // JSON-encoded string array (SQLite limitation)
  values      String    @default("{}") // JSON-encoded object (SQLite: Json stored as TEXT)
  notes       String?
  templateId  String?
  template    Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
  @@index([category])
  @@index([provider])
  @@index([market])
  @@index([environment])
  @@index([templateId])
}

model Template {
  id             String          @id @default(cuid())
  name           String
  description    String?
  category       String?
  provider       String?
  fields         String          @default("[]") // JSON-encoded TemplateField[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  configurations Configuration[]

  @@index([name])
  @@index([category])
}
