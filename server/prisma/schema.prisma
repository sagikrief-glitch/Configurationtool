// prisma/schema.prisma — PostgreSQL (Supabase)
// Restored native Json and String[] types from SQLite workaround

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Configuration {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String?
  type        String    @default("json")
  market      String?
  provider    String?
  environment String?
  tags        String[]
  values      Json      @default("{}")
  notes       String?
  templateId  String?
  template    Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
  @@index([category])
  @@index([provider])
  @@index([market])
  @@index([environment])
  @@index([templateId])
}

model Template {
  id             String          @id @default(cuid())
  name           String
  description    String?
  category       String?
  provider       String?
  fields         Json            @default("[]")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  configurations Configuration[]

  @@index([name])
  @@index([category])
}
